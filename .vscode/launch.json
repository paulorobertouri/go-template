{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Go: Debug API",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/main.go"
    },
    {
      "name": "Go: Debug Current Package Tests",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${fileDirname}"
    },
    {
      "name": "Go: Docker Docs",
      "type": "pwa-chrome",
      "request": "launch",
      "preLaunchTask": "docker:up",
      "postDebugTask": "docker:down",
      "url": "http://localhost:8000/docs",
      "webRoot": "${workspaceFolder}"
    }
  ]
}
